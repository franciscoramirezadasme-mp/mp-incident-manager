# Jira - instancia principal (IXFS)
JIRA_URL=https://mercadolibre-externals.atlassian.net
JIRA_EMAIL=francisco.ramirezadasme@mercadolibre.cl
JIRA_TOKEN=your_jira_api_token_here

# Jira - instancia interna (IXF)
JIRA_INTERNAL_URL=https://mercadolibre.atlassian.net
JIRA_INTERNAL_TOKEN=your_internal_jira_token_here

# Proyectos a monitorear (separados por coma)
JIRA_PROJECTS=IXFS,IXF

# SLA: umbral en minutos sin respuesta antes de marcar como vencido
SLA_THRESHOLD_MINUTES=5

# Intervalo de polling en segundos (300 = 5 minutos)
POLL_INTERVAL_SECONDS=300

# Claude API para generar reportes enriquecidos (opcional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Zona horaria para saludos
TIMEZONE=America/Santiago
